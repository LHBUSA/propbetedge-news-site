/**
 * src/components/header.js
 *
 * Site header. Two nav additions in this revision:
 *   1. "Live" → "Live Games" (clearer label for the scoreboard hub)
 *   2. New "Leaders" link pointing at /leaders (full ESPN-style stat page)
 *
 * Active-state highlighting based on current path.
 */

export function renderHeader() {
  const path = window.location.pathname;
  const isLive    = path === '/games' || path.startsWith('/games/');
  const isLeaders = path === '/leaders' || path.startsWith('/leaders/');
  const isHome    = path === '/';
  const isNews    = path === '/news' || path.startsWith('/news/');

  return `
    <header class="site-header">
      <div class="container site-header-inner">
        <a href="/" class="site-logo">
          <span class="site-logo-mark">PBE</span>
          <span class="site-logo-word">PropBetEdge</span>
        </a>
        <nav class="site-nav">
          <a href="/" class="nav-link ${isHome ? 'active' : ''}">Home</a>
          <a href="/news" class="nav-link ${isNews ? 'active' : ''}">News</a>
          <a href="/games" class="nav-link live-link ${isLive ? 'active' : ''}">
            <span class="live-link-dot"></span>
            Live Games
          </a>
          <a href="/leaders" class="nav-link ${isLeaders ? 'active' : ''}">Leaders</a>
          <a href="https://mlb.propbetedge.ai" class="nav-link nav-link-cta" target="_blank" rel="noopener">
            Picks <span class="nav-link-cta-arrow">→</span>
          </a>
        </nav>
      </div>
    </header>
  `;
}
