/**
 * src/router.js
 *
 * Hash-free SPA router. Vite + Vercel serve all routes through index.html
 * which calls navigate(window.location.pathname) on boot.
 *
 * Route additions in this revision:
 *   /leaders                   → full ESPN-style stat leaders page
 *   /team/:sport/:teamId       → v2 stub
 *   /standings/:sport          → v2 stub
 *   /player/:sport/:playerId   → v2 stub
 *
 * v2 stubs render a "Coming soon" page so leader rows / scoreboard team
 * logos have somewhere to go without dead-clicking. When the real pages
 * land, swap out the stub renderer for the real one.
 */

import { renderHomePage }      from './pages/home.js';
import { renderNewsIndex }     from './pages/news-index.js';
import { renderSportPage }     from './pages/sport.js';
import { renderArticlePage }   from './pages/article.js';
import { renderAuthorPage }    from './pages/author.js';
import { renderGamesHub }      from './pages/games-hub.js';
import { renderGameDetail }    from './pages/game-detail.js';
import { renderLeadersPage }   from './pages/leaders.js';
import { render404 }           from './pages/404.js';

import { renderHeader } from './components/header.js';
import { renderFooter } from './components/footer.js';

export function navigate(path) {
  const root = document.getElementById('app');
  if (!root) return;

  // Update browser URL (without re-loading) when called programmatically
  if (window.location.pathname !== path) {
    window.history.pushState({}, '', path);
  }

  // ── Routes ──────────────────────────────────────────────────────────
  if (path === '/' || path === '/index.html') {
    return renderHomePage(root);
  }
  if (path === '/news') {
    return renderNewsIndex(root);
  }
  if (path === '/games') {
    return renderGamesHub(root);
  }
  if (path === '/leaders') {
    return renderLeadersPage(root);
  }

  // /games/:sport/:gameId
  const gameMatch = path.match(/^\/games\/([a-z]+)\/([\w-]+)$/i);
  if (gameMatch) {
    return renderGameDetail(root, gameMatch[1].toLowerCase(), gameMatch[2]);
  }

  // /news/:sport
  const sportMatch = path.match(/^\/news\/([a-z]+)$/i);
  if (sportMatch) {
    return renderSportPage(root, sportMatch[1].toLowerCase());
  }

  // /article/:slug
  const articleMatch = path.match(/^\/article\/(.+)$/);
  if (articleMatch) {
    return renderArticlePage(root, articleMatch[1]);
  }

  // /author/:slug
  const authorMatch = path.match(/^\/author\/(.+)$/);
  if (authorMatch) {
    return renderAuthorPage(root, authorMatch[1]);
  }

  // ── v2 stub routes ──────────────────────────────────────────────────
  // Leader cards link here. Until the real pages ship, render a clean
  // "coming soon" page that doesn't feel like an error.

  const teamMatch = path.match(/^\/team\/([a-z]+)\/([\w-]+)$/i);
  if (teamMatch) {
    return renderComingSoon(root, {
      kicker: `${teamMatch[1].toUpperCase()} TEAM PAGE`,
      title: 'Team pages launching soon',
      dek: 'Roster, stats, schedule, and standings — coming next. For now, head back to live games or check the latest news.',
      cta: { href: '/games', label: '← Back to live games' },
    });
  }

  const standingsMatch = path.match(/^\/standings\/([a-z]+)$/i);
  if (standingsMatch) {
    return renderComingSoon(root, {
      kicker: `${standingsMatch[1].toUpperCase()} STANDINGS`,
      title: 'Standings tables coming soon',
      dek: 'Division and conference standings, Wild Card races, and full season splits — launching next sprint.',
      cta: { href: '/games', label: '← Back to live games' },
    });
  }

  const playerMatch = path.match(/^\/player\/([a-z]+)\/([\w-]+)$/i);
  if (playerMatch) {
    return renderComingSoon(root, {
      kicker: `${playerMatch[1].toUpperCase()} PLAYER PAGE`,
      title: 'Player pages launching soon',
      dek: 'Bio, season stats, gamelog, splits, and trends — all on one page. Coming in the next release.',
      cta: { href: '/leaders', label: '← Back to leaders' },
    });
  }

  return render404(root);
}

function renderComingSoon(root, opts) {
  root.innerHTML = `
    ${renderHeader()}
    <main>
      <div class="container">
        <div class="leaders-hero" style="margin-top:32px">
          <div class="leaders-hero-mesh"></div>
          <div class="leaders-hero-inner">
            <div class="leaders-hero-kicker">
              <span class="live-dot-big" style="background:var(--gold);box-shadow:0 0 0 0 rgba(212,175,55,0.5)"></span>
              <span>${opts.kicker}</span>
            </div>
            <h1 class="leaders-hero-title">${opts.title}</h1>
            <p class="leaders-hero-dek">${opts.dek}</p>
            <p style="margin-top:18px">
              <a href="${opts.cta.href}" style="color:var(--gold);font-size:15px;font-weight:600;text-decoration:none">${opts.cta.label}</a>
            </p>
          </div>
        </div>
      </div>
    </main>
    ${renderFooter()}
  `;
}

// ── SPA link interception ──────────────────────────────────────────────
document.addEventListener('click', (e) => {
  const link = e.target.closest('a');
  if (!link) return;
  const href = link.getAttribute('href');
  if (!href || href.startsWith('#')) return;
  if (href.startsWith('http://') || href.startsWith('https://') || href.startsWith('mailto:')) return;
  if (link.target === '_blank') return;
  if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;

  e.preventDefault();
  navigate(href);
});

// ── Browser back/forward ───────────────────────────────────────────────
window.addEventListener('popstate', () => {
  navigate(window.location.pathname);
});

// ── Initial render ─────────────────────────────────────────────────────
if (typeof window !== 'undefined') {
  document.addEventListener('DOMContentLoaded', () => {
    navigate(window.location.pathname);
  });
}
